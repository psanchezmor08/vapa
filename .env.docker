# Docker Environment Variables para VAPA.es

# Backend API Secret Key (CAMBIAR EN PRODUCCIÓN)
SECRET_KEY=vapa-production-secret-key-2026-change-this

# Frontend Backend URL (usar la URL de tu servidor)
# Si accedes por IP: http://TU_IP:6000
# Si accedes por dominio: https://vapa.es
REACT_APP_BACKEND_URL=http://localhost:6000
